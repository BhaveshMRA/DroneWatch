# DroneWatch Environment Variables
# Copy this file to .env and fill in your values.
# Get your Gemini API key at: https://aistudio.google.com/app/apikey

# Required
GOOGLE_API_KEY=your_gemini_api_key_here

# Optional — used in multi-agent Docker Compose setup
VISION_AGENT_URL=http://localhost:8001
NYC_AGENT_URL=http://localhost:8002
